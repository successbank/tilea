generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?  @map("email_verified")
  name          String?
  phone         String?
  image         String?
  password      String?
  role          UserRole   @default(GENERAL)
  status        UserStatus @default(ACTIVE)

  onboardingCompleted Boolean @default(false) @map("onboarding_completed")

  agreedTerms     Boolean @default(false) @map("agreed_terms")
  agreedPrivacy   Boolean @default(false) @map("agreed_privacy")
  agreedMarketing Boolean @default(false) @map("agreed_marketing")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  accounts        Account[]
  sessions        Session[]
  businessProfile BusinessProfile?
  cuttingProjects CuttingProject[]
  estimates       Estimate[]
  posts           Post[]
  comments        Comment[]
  pointTransactions PointTransaction[]
  articles        Article[]
  inventories     Inventory[]
  projects        Project[]
  customers       Customer[]
  expenses        Expense[]
  receivables     Receivable[]
  tradePosts      TradePost[]
  auctionRequests AuctionRequest[]
  auctionBids     AuctionBid[]
  reviewsWritten  Review[] @relation("reviewer")
  reviewsReceived Review[] @relation("target")
  products        Product[]
  orders          Order[]
  productReviews  ProductReview[]
  enrollments     Enrollment[]
  courseReviews   CourseReview[]
  sentMessages    Message[]      @relation("sender")
  receivedMessages Message[]     @relation("receiver")
  notifications   Notification[]
  instructorPayouts InstructorPayout[]
  points          Int      @default(0)

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  GENERAL
  BUSINESS
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  businessNumber  String   @unique @map("business_number")
  businessName    String   @map("business_name")
  ownerName       String   @map("owner_name")
  businessType    String?  @map("business_type")
  shopName        String?  @map("shop_name")
  introduction    String?  @db.Text
  specialty       String[]
  address         String?
  addressDetail   String?  @map("address_detail")
  phone           String?
  website         String?

  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  verifiedAt      DateTime? @map("verified_at")

  portfolioImages String[] @map("portfolio_images")

  averageRating   Float    @default(0) @map("average_rating")
  reviewCount     Int      @default(0) @map("review_count")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

model CuttingProject {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String   @default("새 프로젝트")

  sheetWidth   Int      @map("sheet_width")
  sheetHeight  Int      @map("sheet_height")
  sheetPrice   Float?   @map("sheet_price")
  kerf         Float    @default(3)
  grainEnabled Boolean  @default(false) @map("grain_enabled")

  parts        Json
  result       Json?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cutting_projects")
}

model Estimate {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  estimateNo      String         @unique @map("estimate_no")

  customerName    String         @map("customer_name")
  customerPhone   String?        @map("customer_phone")
  customerEmail   String?        @map("customer_email")
  customerAddress String?        @map("customer_address")

  items           Json
  subtotal        Float          @default(0)
  marginRate      Float          @default(10) @map("margin_rate")
  marginAmount    Float          @default(0) @map("margin_amount")
  totalAmount     Float          @default(0) @map("total_amount")

  status          EstimateStatus @default(DRAFT)
  validUntil      DateTime?      @map("valid_until")
  notes           String?        @db.Text
  templateType    String?        @map("template_type")

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("estimates")
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  CONTRACTED
  COMPLETED
  REJECTED
}

// ========== PRD8: 커뮤니티 ==========

model Post {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  board     String
  title     String
  content   String     @db.Text
  images    String[]
  tags      String[]
  views     Int        @default(0)
  likes     Int        @default(0)
  isPinned  Boolean    @default(false) @map("is_pinned")
  status    PostStatus @default(ACTIVE)

  comments  Comment[]
  bookmarks Bookmark[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  parentId  String?  @map("parent_id")
  content   String   @db.Text
  likes     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("replies")

  @@map("comments")
}

model PointTransaction {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  amount    Int
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("bookmarks")
}

enum PostStatus {
  ACTIVE
  HIDDEN
  DELETED
}

// ========== PRD13: 뉴스/정보 ==========

model Article {
  id          String    @id @default(cuid())
  authorId    String    @map("author_id")
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?
  coverImage  String?   @map("cover_image")
  category    String
  tags        String[]
  views       Int       @default(0)
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("articles")
}

model SupportProgram {
  id           String    @id @default(cuid())
  title        String
  organization String
  description  String    @db.Text
  target       String?
  region       String?
  applyStart   DateTime? @map("apply_start")
  applyEnd     DateTime? @map("apply_end")
  applyUrl     String?   @map("apply_url")
  status       String    @default("active")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("support_programs")
}

// ========== PRD5: 재고 관리 ==========

model Inventory {
  id           String              @id @default(cuid())
  userId       String              @map("user_id")
  name         String
  category     InventoryCategory
  spec         String?
  unit         String
  quantity     Float               @default(0)
  unitPrice    Float               @default(0) @map("unit_price")
  minQuantity  Float?              @map("min_quantity")
  location     String?
  barcode      String?
  image        String?

  transactions InventoryTransaction[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("inventories")
}

model InventoryTransaction {
  id          String          @id @default(cuid())
  inventoryId String          @map("inventory_id")
  type        TransactionType
  quantity    Float
  unitPrice   Float?          @map("unit_price")
  note        String?
  date        DateTime        @default(now())

  inventory   Inventory       @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

enum InventoryCategory {
  PANEL
  TIMBER
  HARDWARE
  PAINT
  ACCESSORY
  OTHER
}

enum TransactionType {
  IN
  OUT
}

// ========== PRD6: 프로젝트 관리 ==========

model Project {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  name           String
  status         ProjectStatus @default(RECEIVED)

  customerName   String        @map("customer_name")
  customerPhone  String?       @map("customer_phone")
  customerEmail  String?       @map("customer_email")
  requirements   String?       @db.Text
  startDate      DateTime?     @map("start_date")
  deadline       DateTime?
  budget         Float?
  contractAmount Float?        @map("contract_amount")

  shareToken     String?       @unique @map("share_token")

  logs           ProjectLog[]
  estimateId     String?       @map("estimate_id")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model ProjectLog {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  date        DateTime @default(now())
  content     String   @db.Text
  images      String[]
  hoursWorked Float?   @map("hours_worked")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_logs")
}

enum ProjectStatus {
  RECEIVED
  ESTIMATING
  CONTRACTED
  PRODUCING
  DELIVERING
  COMPLETED
  CANCELLED
}

// ========== PRD7: CRM & 매출/회계 ==========

model Customer {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  phone     String?
  email     String?
  address   String?
  tags      String[]
  memo      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customers")
}

model Expense {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  type        ExpenseType
  category    String
  amount      Float
  description String?
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Receivable {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  customerId  String           @map("customer_id")
  amount      Float
  description String?
  dueDate     DateTime         @map("due_date")
  status      ReceivableStatus @default(PENDING)
  paidAt      DateTime?        @map("paid_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("receivables")
}

enum ExpenseType {
  INCOME
  EXPENSE
}

enum ReceivableStatus {
  PENDING
  PAID
  OVERDUE
}

// ========== PRD9: 중고거래 ==========

model TradePost {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  title       String
  description String      @db.Text
  images      String[]
  price       Float?
  tradeType   TradeType   @map("trade_type")
  category    String
  status      TradeStatus @default(ACTIVE)
  region      String
  district    String?

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trade_posts")
}

enum TradeType {
  SELL
  BUY
  EXCHANGE
  FREE
}

enum TradeStatus {
  ACTIVE
  RESERVED
  TRADE_COMPLETED
  TRADE_HIDDEN
}

// ========== PRD10: 역경매 ==========

model AuctionRequest {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  category    String
  title       String
  description String            @db.Text
  images      String[]
  budgetMin   Float?            @map("budget_min")
  budgetMax   Float?            @map("budget_max")
  deadline    DateTime?
  region      String
  district    String?
  visibility  AuctionVisibility @default(PUBLIC)
  status      AuctionStatus     @default(OPEN)
  bidDeadline DateTime?         @map("bid_deadline")

  bids        AuctionBid[]
  contract    AuctionContract?

  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auction_requests")
}

model AuctionBid {
  id             String    @id @default(cuid())
  requestId      String    @map("request_id")
  bidderId       String    @map("bidder_id")
  price          Float
  priceBreakdown Json?     @map("price_breakdown")
  estimatedDays  Int?      @map("estimated_days")
  portfolio      String[]
  message        String?   @db.Text
  status         BidStatus @default(SUBMITTED)

  createdAt      DateTime  @default(now()) @map("created_at")
  request        AuctionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  bidder         User      @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@map("auction_bids")
}

model AuctionContract {
  id          String         @id @default(cuid())
  requestId   String         @unique @map("request_id")
  bidId       String         @map("bid_id")
  status      ContractStatus @default(IN_PROGRESS)
  completedAt DateTime?      @map("completed_at")

  reviews     Review[]
  createdAt   DateTime       @default(now()) @map("created_at")
  request     AuctionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("auction_contracts")
}

model Review {
  id                  String   @id @default(cuid())
  contractId          String   @map("contract_id")
  reviewerId          String   @map("reviewer_id")
  targetId            String   @map("target_id")
  rating              Float
  qualityRating       Float?   @map("quality_rating")
  communicationRating Float?   @map("communication_rating")
  punctualityRating   Float?   @map("punctuality_rating")
  priceRating         Float?   @map("price_rating")
  content             String?  @db.Text
  images              String[]
  reply               String?  @db.Text

  createdAt           DateTime @default(now()) @map("created_at")
  contract            AuctionContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reviewer            User     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  target              User     @relation("target", fields: [targetId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum AuctionVisibility {
  PUBLIC
  PRIVATE
}

enum AuctionStatus {
  OPEN
  BIDDING
  SELECTED
  AUCTION_CONTRACTED
  AUCTION_COMPLETED
  CANCELLED
}

enum BidStatus {
  SUBMITTED
  SELECTED
  BID_REJECTED
}

enum ContractStatus {
  IN_PROGRESS
  CONTRACT_COMPLETED
  DISPUTED
}

// ========== PRD11: 마켓플레이스 상품 ==========

model Product {
  id            String        @id @default(cuid())
  sellerId      String        @map("seller_id")
  title         String
  description   String        @db.Text
  categoryId    String        @map("category_id")
  price         Float
  salePrice     Float?        @map("sale_price")
  stock         Int           @default(0)
  images        String[]
  videoUrl      String?       @map("video_url")
  specs         Json?
  brand         String?
  status        ProductStatus @default(ACTIVE)
  averageRating Float         @default(0) @map("average_rating")
  reviewCount   Int           @default(0) @map("review_count")
  salesCount    Int           @default(0) @map("sales_count")

  category      ProductCategory @relation(fields: [categoryId], references: [id])
  seller        User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  reviews       ProductReview[]
  orderItems    OrderItem[]

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("products")
}

model ProductCategory {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  parentId  String?            @map("parent_id")
  depth     Int                @default(0)
  sortOrder Int                @default(0) @map("sort_order")

  parent    ProductCategory?   @relation("subcategories", fields: [parentId], references: [id])
  children  ProductCategory[]  @relation("subcategories")
  products  Product[]

  @@map("product_categories")
}

model ProductReview {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  rating    Float
  content   String?  @db.Text
  images    String[]
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("product_reviews")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  SOLDOUT
}

// ========== PRD12: 주문/결제 ==========

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique @map("order_no")
  buyerId     String      @map("buyer_id")
  totalAmount Float       @map("total_amount")
  status      OrderStatus @default(PENDING)

  items       OrderItem[]
  payment     Payment?
  shipping    ShippingInfo?

  buyer       User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  sellerId  String  @map("seller_id")
  quantity  Int
  unitPrice Float   @map("unit_price")
  amount    Float

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id         String        @id @default(cuid())
  orderId    String        @unique @map("order_id")
  paymentKey String        @unique @map("payment_key")
  method     String
  amount     Float
  status     PaymentStatus @default(PAYMENT_PENDING)
  approvedAt DateTime?     @map("approved_at")

  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ShippingInfo {
  id               String         @id @default(cuid())
  orderId          String         @unique @map("order_id")
  carrier          String?
  trackingNo       String?        @map("tracking_no")
  status           ShippingStatus @default(PREPARING)
  shippedAt        DateTime?      @map("shipped_at")
  deliveredAt      DateTime?      @map("delivered_at")
  recipientName    String         @map("recipient_name")
  recipientPhone   String         @map("recipient_phone")
  recipientAddress String         @map("recipient_address")

  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipping_infos")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPING
  DELIVERED
  ORDER_COMPLETED
  ORDER_CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PAYMENT_PENDING
  APPROVED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
}

enum ShippingStatus {
  PREPARING
  SHIPPED
  SHIP_DELIVERED
}

// ========== PRD14-15: 온라인 클래스 ==========

model Course {
  id            String         @id @default(cuid())
  instructorId  String         @map("instructor_id")
  title         String
  slug          String         @unique
  description   String         @db.Text
  coverImage    String?        @map("cover_image")
  category      String
  price         Float          @default(0)
  salePrice     Float?         @map("sale_price")
  level         String?
  isPublished   Boolean        @default(false) @map("is_published")
  averageRating Float          @default(0) @map("average_rating")
  reviewCount   Int            @default(0) @map("review_count")
  enrollCount   Int            @default(0) @map("enroll_count")

  sections      CourseSection[]
  enrollments   Enrollment[]
  reviews       CourseReview[]

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("courses")
}

model CourseSection {
  id        String   @id @default(cuid())
  courseId   String   @map("course_id")
  title     String
  sortOrder Int      @default(0) @map("sort_order")

  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_sections")
}

model Lesson {
  id        String   @id @default(cuid())
  sectionId String   @map("section_id")
  title     String
  videoUrl  String?  @map("video_url")
  duration  Int?
  isFree    Boolean  @default(false) @map("is_free")
  sortOrder Int      @default(0) @map("sort_order")
  quiz      Json?

  progress  LessonProgress[]
  section   CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model Enrollment {
  id          String    @id @default(cuid())
  courseId     String    @map("course_id")
  userId      String    @map("user_id")
  paymentId   String?   @map("payment_id")
  progress    Float     @default(0)
  completedAt DateTime? @map("completed_at")

  lessonProgress LessonProgress[]
  createdAt   DateTime  @default(now()) @map("created_at")
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@map("enrollments")
}

model LessonProgress {
  id             String     @id @default(cuid())
  enrollmentId   String     @map("enrollment_id")
  lessonId       String     @map("lesson_id")
  watchedSeconds Int        @default(0) @map("watched_seconds")
  isCompleted    Boolean    @default(false) @map("is_completed")
  completedAt    DateTime?  @map("completed_at")

  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}

model CourseReview {
  id        String   @id @default(cuid())
  courseId   String   @map("course_id")
  userId    String   @map("user_id")
  rating    Float
  content   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@map("course_reviews")
}

model InstructorPayout {
  id           String       @id @default(cuid())
  instructorId String       @map("instructor_id")
  period       String
  grossAmount  Float        @map("gross_amount")
  commission   Float
  tax          Float
  netAmount    Float        @map("net_amount")
  status       PayoutStatus @default(PAYOUT_PENDING)
  paidAt       DateTime?    @map("paid_at")

  instructor   User         @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("instructor_payouts")
}

enum PayoutStatus {
  PAYOUT_PENDING
  PROCESSING
  PAYOUT_PAID
}

// ========== PRD16: 메시징/알림 ==========

model Message {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String   @db.Text
  images     String[]
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  sender     User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
