# ============================================
# tilea.kr 환경변수 템플릿
# Coolify 배포 시 ${VAR} 문법만 사용
# ============================================

# === 프로젝트 ===
PROJECT_NAME=tilea.kr
NODE_ENV=production

# === 포트 (개발용) ===
WEB_PORT=5679
DB_PORT=5680
REDIS_PORT=5681
ADMINER_PORT=5682
MEILISEARCH_PORT=5683

# === 데이터베이스 ===
DB_NAME=tilea_db
DB_USER=tilea_user
DB_PASSWORD=your_db_password_here

# === Redis ===
REDIS_PASSWORD=your_redis_password_here

# === Auth.js (NextAuth v5) ===
NEXTAUTH_URL=https://tilea.kr
NEXTAUTH_SECRET=your_nextauth_secret_here

# === 소셜 로그인 ===
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === 이메일 (Resend) ===
RESEND_API_KEY=

# === 국세청 사업자 조회 ===
NTS_API_KEY=

# === Cloudflare R2 (파일 저장) ===
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=tilea-uploads

# === Meilisearch (검색) ===
MEILISEARCH_MASTER_KEY=your_meili_key_here

# === 결제 (토스페이먼츠) ===
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# === 모니터링 ===
SENTRY_DSN=
UMAMI_WEBSITE_ID=
UMAMI_URL=https://analytics.tilea.kr
